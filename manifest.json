{
  "manifest_version": 3,
  "name": "MDEase",
  "version": "1.0.1",
  "description": "WYSIWYG Markdown editor for local .md files with draft storage and export.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["scripting", "storage"],
  "host_permissions": ["file:///*", "https://open.bigmodel.cn/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["file:///*/*.md", "file:///*/*.markdown", "file:///*/*.mdown"],
      "js": [
        "lib/marked.min.js",
        "lib/highlight.min.js",
        "lib/turndown.js",
        "db.js",
        "content.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
